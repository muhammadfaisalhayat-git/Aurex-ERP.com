# =============================================
# Aurex ERP — Google Cloud Run Environment
# =============================================
# Copy this to .env before deploying manually,
# OR pass these as --set-env-vars to Cloud Run.
# deploy-gcp.ps1 sets these automatically.
# =============================================

APP_NAME="Aurex ERP"
APP_ENV=production
APP_KEY=base64:GENERATE_WITH_php_artisan_key_generate
APP_DEBUG=false
APP_URL=https://YOUR_CLOUD_RUN_URL.a.run.app

LOG_CHANNEL=stderr
LOG_LEVEL=error

# ---- PostgreSQL via Cloud SQL (Unix Socket for Cloud Run) ----
DB_CONNECTION=pgsql
DB_HOST=/cloudsql/YOUR_PROJECT_ID:us-central1:aurex-erp-db
DB_PORT=5432
DB_DATABASE=aurex_erp
DB_USERNAME=aurex_user
DB_PASSWORD=AurexSecure2024!

# ---- Caching (file-based, no Redis required on Cloud Run) ----
CACHE_DRIVER=file
SESSION_DRIVER=file
QUEUE_CONNECTION=sync
FILESYSTEM_DISK=local

# ---- App Defaults ----
DEFAULT_LANGUAGE=en
DEFAULT_CURRENCY=SAR
DEFAULT_TAX_RATE=15
